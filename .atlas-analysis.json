  "keyFeatures": [
    "Live online draughts games with real-time play",
    "Multiple draughts variants: Standard, Frisian, Antidraughts, Frysk!, Breakthrough, Russian, Brazilian",
    "Tournaments (Swiss and Arena formats) and simultaneous exhibitions",
    "Tactics puzzles for all supported variants",
    "Game analysis with Scan 3.1 engine integration",
    "Shared studies and collaborative analysis",
    "Teams, forums, and social features",
    "OAuth2 API for third-party integrations and bots",
    "Available in 27+ languages",
    "Free, open-source, and ad-free"
  ],
  "publicApiSurface": [
    "GET /api/user/:name — Get user profile",
    "GET /api/user/:name/activity — Get user activity",
    "GET /api/game/:id — Get a single game",
    "GET /api/games/user/:username — Export games by user",
    "GET /api/tournament — Get current tournaments",
    "GET /api/tournament/:id — Get tournament details",
    "POST /api/challenge/:user — Create a challenge",
    "GET /api/bot/game/stream/:id — Stream bot game events",
    "POST /api/bot/game/:id/move/:uci — Make a bot move",
    "GET /api/account — Get authenticated user account",
    "GET /api/account/playing — Get games currently being played",
    "POST /api/stream/games-by-users — Stream games by user list",
    "GET /api/stream/event — Stream incoming events",
    "GET /api/team/:id — Get team info",
    "GET /api/swiss/:id/games — Get Swiss tournament games"
  ]
